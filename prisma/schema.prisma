datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-id-of-js"
}

model Meme {
  id              Int      @id @default(autoincrement())
  url             String
  weatherCategory String   // Например: 'Clouds', 'Rain', 'Clear'
  description     String?
  likes           Int      @default(0)
  createdAt       DateTime @default(now())
}