generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Сама таблица мемов
model Meme {
  id              Int      @id @default(autoincrement())
  url             String
  weatherCategory String   // Например: 'Rain', 'Clouds', 'Clear'
  description     String?
}